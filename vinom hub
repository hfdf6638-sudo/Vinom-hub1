--// SERVICES
local player = game.Players.LocalPlayer
local uis = game:GetService("UserInputService")
local rs = game:GetService("RunService")

--// VARS
local spinbot = false
local infjump = false
local autograb = false
local autoLeft = false
local autoRight = false

--// POSITIONS
local L1 = Vector3.new(-476.48, -6.28, 92.73)
local LEND = Vector3.new(-483.12, -4.95, 94.80)

local R1 = Vector3.new(-476.16, -6.52, 25.62)
local REND = Vector3.new(-483.04, -5.09, 23.14)

--// GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,220,0,300)
frame.Position = UDim2.new(0.3,0,0.3,0)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Active = true
Instance.new("UICorner", frame)

-- TITLE
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,40)
title.BackgroundColor3 = Color3.fromRGB(0,150,255)
title.Text = "VINOM HUB"
title.TextScaled = true
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.GothamBold
Instance.new("UICorner", title)

-- DRAG
local dragging = false
local dragStart, startPos

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

uis.InputChanged:Connect(function(input)
	if dragging then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

-- BUTTON FUNCTION
local function btn(name, y, func)
	local b = Instance.new("TextButton", frame)
	b.Size = UDim2.new(0.9,0,0,35)
	b.Position = UDim2.new(0.05,0,0,y)
	b.Text = name
	b.BackgroundColor3 = Color3.fromRGB(40,40,40)
	b.TextColor3 = Color3.new(1,1,1)
	b.TextScaled = true
	Instance.new("UICorner", b)
	b.MouseButton1Click:Connect(func)
end

-- BUTTONS
btn("Spin", 50, function() spinbot = not spinbot end)
btn("Infinite Jump", 90, function() infjump = not infjump end)
btn("Auto Steal", 130, function() autograb = not autograb end)
btn("Auto Left", 170, function() autoLeft = true end)
btn("Auto Right", 210, function() autoRight = true end)

-- SPIN
rs.Heartbeat:Connect(function()
	if spinbot then
		local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if hrp and not hrp:FindFirstChild("Spin") then
			local bv = Instance.new("BodyAngularVelocity")
			bv.Name = "Spin"
			bv.MaxTorque = Vector3.new(0, math.huge, 0)
			bv.AngularVelocity = Vector3.new(0, 60, 0)
			bv.Parent = hrp
		end
	end
end)

-- JUMP
uis.JumpRequest:Connect(function()
	if infjump then
		local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 60, hrp.AssemblyLinearVelocity.Z)
		end
	end
end)

-- AUTO STEAL (شغال فعلي)
rs.Heartbeat:Connect(function()
	if autograb then
		local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		
		for _,v in pairs(workspace:GetDescendants()) do
			if v:IsA("ProximityPrompt") and v.Parent:IsA("BasePart") then
				if (hrp.Position - v.Parent.Position).Magnitude < 20 then
					fireproximityprompt(v)
				end
			end
		end
	end
end)

-- AUTO LEFT
rs.Heartbeat:Connect(function()
	if autoLeft then
		local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		hrp.CFrame = CFrame.new(L1)
		task.wait(0.3)
		hrp.CFrame = CFrame.new(LEND)
		autoLeft = false
	end
end)

-- AUTO RIGHT
rs.Heartbeat:Connect(function()
	if autoRight then
		local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		hrp.CFrame = CFrame.new(R1)
		task.wait(0.3)
		hrp.CFrame = CFrame.new(REND)
		autoRight = false
	end
end)

print("🔥 VINOM HUB WORKING 100%")
